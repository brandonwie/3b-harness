{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {},
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(**/.local/**)",
      "Read(.local/**)",
      "WebSearch",
      "Bash(git commit:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(ls:*)",
      "Bash(git add:*)",
      "Bash(chmod:*)",
      "Bash(~/.claude/statusline-wrapper.sh)",
      "Read($HOME/dev/**)",
      "Read($HOME/.config/**)",
      "Read($HOME/.claude/**)",
      "Edit($HOME/.claude/**)",
      "Write($HOME/.claude/**)",
      "Edit($HOME/dev/**)",
      "Write($HOME/dev/**)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge:*)",
      "Bash(git merge-base:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git -C:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh pr:*)",
      "Bash(gh release:*)",
      "Bash(aws cloudwatch get-metric-statistics:*)",
      "Bash(aws ecs describe-tasks:*)",
      "Bash(aws ecs list-clusters:*)",
      "Bash(aws ecs list-tasks:*)",
      "Bash(aws ecs describe-services:*)",
      "Bash(aws logs:*)",
      "Bash(aws secretsmanager get-secret-value:*)",
      "Bash(aws secretsmanager list-secrets:*)",
      "Bash(aws secretsmanager describe-secret:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws s3 cp:*)",
      "Bash(aws rds describe:*)",
      "Bash(aws ec2 describe:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(mv:*)",
      "Bash(sed:*)",
      "Bash(xargs:*)",
      "Bash(echo:*)",
      "Bash(zsh:*)",
      "Bash(for:*)",
      "Bash(~/.claude/*)",
      "WebFetch(domain:docs.nestjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:code.claude.com)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__ide__getDiagnostics",
      "Bash(git cherry-pick:*)",
      "Bash(git pull:*)",
      "Bash(git restore:*)",
      "Bash(git revert:*)",
      "Bash(nvm ls-remote:*)",
      "Bash(nvm install:*)",
      "Bash(nvm alias:*)",
      "Bash(brew list:*)",
      "Bash(asdf plugin list:*)",
      "Bash(source ~/.nvm/nvm.sh)",
      "Bash(nvm list:*)",
      "Bash(nvm use:*)",
      "Bash(asdf:*)",
      "Bash(java:*)",
      "Bash(brew uninstall:*)",
      "Bash(markdownlint-cli2:*)",
      "Bash(gh project list:*)",
      "Bash(git check-ignore:*)",
      "Skill(issue-creator)",
      "Skill(pr-creator)",
      "Bash(gh repo view:*)",
      "Skill(project-context-loader)",
      "Bash(git rev-list:*)",
      "Bash(yamllint:*)",
      "Bash(python3:*)",
      "Bash(curl:*)",
      "Bash(git remote get-url:*)",
      "Skill(validate-pr-reviews)",
      "Bash(claude:*)",
      "Bash(mkdir:*)",
      "Bash(gh project item-list:*)",
      "Bash(gh auth:*)",
      "mcp__plugin_github_github__pull_request_read",
      "mcp__plugin_github_github__create_pull_request",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(gh:*)",
      "Bash(lsof:*)",
      "Bash(ps:*)"
    ],
    "deny": [],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git clean:*)",
      "Bash(rm:*)"
    ],
    "defaultMode": "default",
    "additionalDirectories": []
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-wrapper.sh"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.12"
}
